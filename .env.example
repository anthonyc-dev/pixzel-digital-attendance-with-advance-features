# Copy to `.env` or `.env.local` and fill in values from the Supabase dashboard:
# Project Settings → API → Project URL and anon / service_role keys.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Required for payroll API routes + `npm run set-payroll-admin` (never expose to the browser).
SUPABASE_SERVICE_ROLE_KEY=
