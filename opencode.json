{
  "agents": {
    "build": {
      "model": "minimax/minimax-m2.5-free",
      "temperature": 0.1,
      "maxSteps": 15,
      "permission": {
        "edit": "ask",
        "bash": "ask"
      },
      "prompt": "You are a senior engineer. Before ANY file edit or bash command, state your exact intention in a 'Plan:' block. Wait for approval."
    },
    "autofixer": {
      "model": "minimax/minimax-m2.5-free",
      "bashCommands": {
        "git revert": "allow",
        "git checkout": "allow",
        "npm run *": "ask"
      }
    }
  }
}
